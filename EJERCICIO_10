ORG 1000H
PALABRA DB "Organizacion ac acl"
FIN_PALABRA DB ?
LETRA1 DB 'a'
LETRA2 DB 'c'
ORG 1200H
TOTAL DB ?

ORG 2000H
MOV BX, OFFSET PALABRA
MOV DH, OFFSET FIN_PALABRA - OFFSET PALABRA
MOV CH,LETRA1
MOV CL,LETRA2
MOV AL,0
COMPARO_LETRA1: CMP CH,[BX]
JNZ NO_ES_LETRA
INC BX
DEC DH
CMP DH,0
JZ FIN
CMP CL,[BX]
JNZ NO_ES_LETRA
INC AL
NO_ES_LETRA: INC BX
DEC DH
CMP DH,0
JNZ COMPARO_LETRA1
FIN: MOV TOTAL,AL
HLT
END
